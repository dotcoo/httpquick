{
  "name": "httpquick",
  "version": "1.2.0",
  "description": "js http quick request",
  "author": "dotcoo <dotcoo@163.com> (http://blog.dotcoo.com)",
  "homepage": "https://github.com/dotcoo/httpquick#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dotcoo/httpquick.git"
  },
  "license": "ISC",
  "keywords": [
    "http",
    "quick",
    "request"
  ],
  "files": [
    "dist",
    "types.d.ts"
  ],
  "type": "module",
  "types": "./types.d.ts",
  "main": "./dist/httpquick.umd.cjs",
  "module": "./dist/ajax.js",
  "exports": {
    ".": {
      "types": "./types.d.ts",
      "import": "./dist/ajax.js"
    },
    "./ajax": {
      "types": "./types.d.ts",
      "import": "./dist/ajax.js"
    },
    "./fetch": {
      "types": "./types.d.ts",
      "import": "./dist/fetch.js"
    },
    "./uniapp": {
      "types": "./types.d.ts",
      "import": "./dist/uniapp.js"
    },
    "./xcx": {
      "types": "./types.d.ts",
      "import": "./dist/xcx.js"
    },
    "./node": {
      "types": "./types.d.ts",
      "import": "./dist/node.js",
      "require": "./dist/node.cjs"
    },
    "./fibjs": {
      "types": "./types.d.ts",
      "import": "./dist/fibjs.js",
      "require": "./dist/fibjs.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --mode=cjs --emptyOutDir=false && vite build --mode=umd --emptyOutDir=false",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.2",
    "pinia": "^3.0.4",
    "vite": "^7.2.4",
    "vue": "^3.5.25",
    "vue-router": "^4.6.3"
  }
}
